{
    "name": "stitch-digital/laravel-pdfmerger",
    "type": "library",
    "description": "Generic PDF merger for Laravel",
    "keywords": [
        "stitch-digital",
        "laravel",
        "pdf",
        "merger",
        "pdfmerger"
    ],
    "homepage": "https://github.com/stitch-digital/laravel-pdfmerger",
    "license": "MIT",
    "authors": [
        {
            "name": "Stitch Digital",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": ">=5.5.9",
        "illuminate/support": ">=5.0",
        "setasign/fpdf": "1.8.*",
        "setasign/fpdi": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "4.*",
        "scrutinizer/ocular": "~1.1",
        "squizlabs/php_codesniffer": "~2.3"
    },
    "autoload": {
        "psr-4": {
            "StitchDigital\\PDFMerger\\": "src/PDFMerger"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "StitchDigital\\PDFMerger\\Test\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0-dev"
        },
        "laravel": {
            "providers": [
                "StitchDigital\\PDFMerger\\Providers\\PDFMergerServiceProvider"
            ],
            "aliases": {
                "PDFMerger": "StitchDigital\\PDFMerger\\Facades\\PDFMergerFacade"
            }
        }
    }
}

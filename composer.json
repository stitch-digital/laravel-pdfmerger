{
    "name": "stitch-digital/laravel-pdfmerger",
    "type": "library",
    "description": "Modern PDF merger for Laravel with fluent API and full type safety",
    "keywords": [
        "stitch-digital",
        "laravel",
        "pdf",
        "merger",
        "pdfmerger",
        "pdf-merge",
        "laravel-pdf"
    ],
    "homepage": "https://github.com/stitch-digital/laravel-pdfmerger",
    "license": "MIT",
    "authors": [
        {
            "name": "Stitch Digital",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/filesystem": "^12.0|^13.0",
        "setasign/fpdf": "^1.8",
        "setasign/fpdi": "^2.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0|^13.0",
        "orchestra/testbench": "^10.0|^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "StitchDigital\\PDFMerger\\": "src/PDFMerger"
        },
        "files": [
            "src/PDFMerger/polyfills.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "StitchDigital\\PDFMerger\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "review": [
          "@format",
          "@analyse",
          "@test"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "StitchDigital\\PDFMerger\\Providers\\PDFMergerServiceProvider"
            ],
            "aliases": {
                "PDFMerger": "StitchDigital\\PDFMerger\\Facades\\PDFMergerFacade"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
